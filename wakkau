<script>
const SLOT_SYMBOLS = [
  { icon:"🍒", name:"Cherry", multi:2 },
  { icon:"🍋", name:"Lemon", multi:3 },
  { icon:"🔔", name:"Bell", multi:5 },
  { icon:"⭐", name:"Star", multi:8 },
  { icon:"7️⃣", name:"Seven", multi:12 },
  { icon:"💎", name:"Diamond", multi:20 }
];

const $ = (q) => document.querySelector(q);
const randInt = (min,max) => Math.floor(Math.random()*(max-min+1))+min;

function randomSymbol(){
  return SLOT_SYMBOLS[randInt(0, SLOT_SYMBOLS.length - 1)];
}

function calcWin(reels, bet, mode){
  const [a,b,c] = reels;

  let bonus = 1;
  if(mode === "turbo") bonus = 1.2;
  if(mode === "bonus") bonus = 1.6;

  if(a.icon === b.icon && b.icon === c.icon){
    return {
      result: "BIG WIN",
      symbol: a.name,
      multi: a.multi * 3,
      total: Math.floor(bet * a.multi * 3 * bonus)
    };
  }

  if(a.icon === b.icon || b.icon === c.icon || a.icon === c.icon){
    const pair = a.icon === b.icon ? a : (b.icon === c.icon ? b : a);
    return {
      result: "WIN",
      symbol: pair.name,
      multi: pair.multi,
      total: Math.floor(bet * pair.multi * bonus)
    };
  }

  return {
    result: "LOSE",
    symbol: "-",
    multi: 0,
    total: 0
  };
}

function addHistory(reels, result, total){
  const wrap = $("#slotAltList");
  const div = document.createElement("div");
  div.className = "slot-alt-item";
  div.innerHTML = `
    <div class="g">${reels.map(r => r.icon).join(" ")}</div>
    <div class="p">${result}</div>
    <div class="r">${total > 0 ? "WIN " + total : "NO WIN"}</div>
  `;
  wrap.prepend(div);

  while(wrap.children.length > 3){
    wrap.removeChild(wrap.lastChild);
  }
}

document.addEventListener("DOMContentLoaded", () => {
  const reelsWrap = $("#slotReels");
  const reelsEls = reelsWrap.querySelectorAll(".slot-reel");
  const btn = $("#btnSpinSlot");

  btn.addEventListener("click", async () => {
    const bet = parseInt($("#betFilter").value, 10);
    const mode = $("#modeFilter").value;
    const lines = parseInt($("#lineCount").value, 10);

    $("#slotStatus").textContent = "— SPINNING —";
    $("#rMode").textContent = mode.toUpperCase();
    $("#rBet").textContent = bet;
    $("#rLines").textContent = lines;

    reelsEls.forEach(el => {
      el.classList.add("reel-spin");
      el.textContent = SLOT_SYMBOLS[randInt(0, SLOT_SYMBOLS.length - 1)].icon;
    });

    setTimeout(() => {
      const reels = [randomSymbol(), randomSymbol(), randomSymbol()];

      reelsEls.forEach((el, i) => {
        el.classList.remove("reel-spin");
        el.textContent = reels[i].icon;
      });

      const outcome = calcWin(reels, bet, mode);

      $("#rWin").textContent = outcome.total;
      $("#rSymbol").textContent = outcome.symbol;
      $("#rMulti").textContent = "x" + outcome.multi;
      $("#rResult").textContent = outcome.result;
      $("#slotStatus").textContent = outcome.result === "LOSE" ? "— TRY AGAIN —" : "— " + outcome.result + " —";

      addHistory(reels, outcome.result, outcome.total);
    }, 1000);
  });
});
</script>
